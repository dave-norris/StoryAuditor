{
  "name": "story-auditor",
  "version": "1.0.0",
  "description": "A website for auditing stories",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc && npm run copy-public",
    "copy-public": "mkdir -p dist/public && cp public/index.html dist/public/ && cp public/styles.css dist/public/",
    "start": "node dist/src/server.js",
    "dev": "ts-node src/server.ts"
  },
  "keywords": [
    "story",
    "auditor"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  }
}
